<%- include("partials/header.ejs") %>
<div class="page-header"> 
<h1>WELCOME TO LIBRAREX</h1>
<p>Books i've read and loved</p>
</div>

<form action="/addBook" method="POST" class="add-section">
    <div class="form-group">
        <label for="addBook">Add a book</label>
        <input id="addBook" type="text" name="addBook" placeholder="Lord of the Rings" required>
    </div>
    
    <div class="form-group" id="reviewSection">
        <label for="review">Write your review</label>
        <textarea id="review" name="review" placeholder="Great book because..." required></textarea>
    </div>

    <div class="form-group" id="ratingSection">
        <label for="rating">Rating</label>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <select id="rating" name="rating" style="width: auto;">
                <% for(let i=1; i<=10; i++) { %>
                    <option value="<%= i %>"><%= i %></option>
                <%}%>
            </select>
            <span style="font-size: 0.95rem; opacity: 0.75;">/10</span>
        </div>
    </div>
    
    <input type="submit" value="Add Book">
</form>

<div class="books-grid">
    <% locals.books.forEach((book) => { %>
        <a href="/book/<%= book.id %>" class="book-card" >
            <div class="book-card-body" >
        <h2> <%= book.title %></h2>
         <div class="rating">
                    <span class="rating-number"><%= book.rating %></span>
                    <span class="rating-label">out of 10</span>
                </div>
        </div>
        </a>
   <% }); %>
</div>

<%- include("partials/footer.ejs") %>