<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <meta name="description" content="Librarex – Personal reading sanctuary to catalog, review, and rate books.">
    <meta property="og:title" content="Librarex">
    <meta property="og:description" content="Personal reading sanctuary to catalog, review, and rate books.">
    <meta property="og:image" content="/static/og-image.png">
    <meta property="og:url" content="https://yourdomain.com/">
    <meta name="twitter:card" content="summary_large_image">
    <title>Librarex</title>
</head>
<body>
    <nav>
        <a href="/" class="logo">Librarex</a>
        <div class="nav-links">
            <% if (locals.isAuthenticated) { %>
                <a href="/logout">Logout</a>
            <% } else { %>
                <a href="/login" class="nav-link">Sign In</a>
                <a href="/register" class="nav-link btn-nav">Register</a>
            <% } %>
        </div>
    </nav>